{% stylesheet %}
  .footer {
    padding: 80px 0 40px;
    background: #111;
    color: #fff;
  }

  .page-width {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }

  .footer h3 {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__menu li + li {
    margin-top: 0.75rem;
  }

  .footer__menu a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer__menu a:hover {
    opacity: 0.7;
  }

  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .footer-newsletter input {
    padding: 0.9rem 1rem;
    border: 1px solid #444;
    background: transparent;
    color: #fff;
    font-size: 1rem;
  }

  .footer-newsletter input::placeholder {
    color: #aaa;
  }

  .footer-newsletter button {
    padding: 0.9rem 1rem;
    border: none;
    background: #fff;
    color: #111;
    cursor: pointer;
    font-size: 1rem;
    transition: 0.2s;
  }

  .footer-newsletter button:hover {
    opacity: 0.9;
  }

  .success {
    color: #7dd87d;
    margin-top: 0.5rem;
  }

  .footer__bottom {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #333;
    text-align: center;
    font-size: 0.9rem;
    color: #aaa;
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
{% endstylesheet %}

<footer class="footer">
  <div class="page-width">
    {% comment %}
      loop for footer blocks
    {% endcomment %}
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'menu' %}
          <div class="footer__column">
            <h3>{{ block.settings.menu_title }}</h3>

            <ul class="footer__menu">
              {% for link in linklists[block.settings.menu_links].links %}
                <li>
                  <a href="{{ link.url }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% when 'newsletter' %}
          <div class="footer__column">
            <h3>Newsletter</h3>

            <p>Subscribe to receive updates, exclusive offers and new arrivals.</p>

            {% form 'contact', class: 'footer-newsletter' %}
              <input type="hidden" name="contact[tags]" value="newsletter">

              <input
                type="email"
                name="contact[email]"
                placeholder="Email address"
                required
                autocorrect="off"
                autocapitalize="off"
              >

              <button type="submit">Subscribe</button>

              {% if form.posted_successfully? %}
                <p class="success">Thank you for subscribing!</p>
              {% endif %}

              {% if form.errors %}
                {{ form.errors | default_errors }}
              {% endif %}
            {% endform %}
          </div>
          </div>
      {% endcase %}
    {% endfor %}

    <div class="footer__bottom">
      <p>
        &copy; {{ 'now' | date: '%Y' }}
        {{ shop.name }}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "blocks": [
    {
      "type": "menu",
      "name": "Footer Menu",
      "settings": [
        {
          "type": "text",
          "id": "menu_title",
          "label": "Menu Title",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu_links",
          "label": "Menu Links"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter Signup",
      "settings": []
    }
  ]
}
{% endschema %}
