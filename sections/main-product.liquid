{% stylesheet %}
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .product-container {
    margin: auto;
    display: flex;
    gap: 40px;
    margin: 45px auto 0 auto;
  }

  .product-image {
    flex: 1;
  }

  .product-image img {
    width: 100%;
  }

  .product-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .product-title {
    font-size: 1.5rem;
    margin-bottom: 15px;
    color: #222;
  }

  .product-price {
    font-size: 1rem;
    margin-bottom: 20px;
    font-weight: bold;
  }

  .product-description {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 30px;
  }

  .add-to-cart {
    padding: 15px 25px;
    font-size: 1rem;
    border: none;
    background-color: #000;
    color: #fff;
    cursor: pointer;
    border-radius: 6px;
    transition: background 0.3s ease;
    width: fit-content;
    margin: 30px 0 0 0;
  }

  .add-to-cart:hover {
    background-color: #333;
  }

  @media (max-width: 768px) {
    .product-container {
      flex-direction: column;
    }
  }
{% endstylesheet %}

<div class="product-container container">
  <div class="product-image">
    <img
      src="{{ product.featured_image | image_url: width: 400 }}"
      alt="Product Image"
    >
  </div>

  <div class="product-details">
    <h1 class="product-title">{{ product.title }}</h1>

    <div class="product-price">{{ product.price | money }}</div>

    <div class="product-description">
      {{ product.description }}
    </div>

    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button class="add-to-cart">Add to Cart</button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Main Product"
    }
  ]
}
{% endschema %}
