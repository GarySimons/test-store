{% stylesheet %}
  .product-container {
    max-width: 1200px;
    margin: 45px auto 0;
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .product-image,
  .product-details {
    flex: 1;
  }

  .product-image img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  .product-details {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .product-title {
    font-size: 2rem;
    margin-bottom: 15px;
    color: #222;
  }

  .product-price {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .product-description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #555;
  }

  .add-to-cart {
    margin-top: 30px;
    padding: 15px 30px;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  .add-to-cart:hover {
    background: #333;
  }

  .placeholder-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .product-container {
      flex-direction: column;
      gap: 30px;
    }

    .product-title {
      font-size: 1.6rem;
    }

    .product-details {
      width: 100%;
    }
  }
{% endstylesheet %}

<div class="product-container container">
  <div class="product-image">
    {% if product.featured_image %}
      {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, loading: 'lazy' }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>

  <div class="product-details">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'title' %}
          <h1 class="product-title" {{ block.shopify_attributes }}>{{ product.title }}dddd</h1>

        {% when 'price' %}
          <div class="product-price" {{ block.shopify_attributes }}>
            {{ product.price | money }}
          </div>

        {% when 'description' %}
          <div class="product-description" {{ block.shopify_attributes }}>
            {{ product.description }}
          </div>

        {% when 'add-to-cart' %}
          {% form 'product', product %}
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
            >

            <button type="submit" class="add-to-cart">Add to Cart</button>
          {% endform %}
      {% endcase %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "title",
      "name": "Title"
    },
    {
      "type": "price",
      "name": "Price"
    },
    {
      "type": "description",
      "name": "Description"
    },
    {
      "type": "add-to-cart",
      "name": "Add to Cart Button"
    }
  ],
  "presets": [
    {
      "name": "Main Product",
      "blocks": [
        {
          "type": "title"
        },
        {
          "type": "price"
        },
        {
          "type": "description"
        },
        {
          "type": "add-to-cart"
        }
      ]
    }
  ]
}
{% endschema %}
