{% stylesheet %}
  .featured-collection__title {
    text-align: center;
    margin-bottom: 30px;
    font-size: 28px;
  }

  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .featured-collection__item {
    text-align: center;
  }

  .featured-collection__item img {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 10px;
  }

  .featured-collection__item h3 {
    font-size: 16px;
    margin: 10px 0 5px;
  }

  @media (max-width: 768px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

<section class="featured-collection container">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="featured-collection__title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% assign collection = collections[section.settings.collection] %}

    {% if collection != blank and collection.products_count > 0 %}
      <div class="featured-collection__grid">
        {% for product in collection.products limit: section.settings.products_limit %}
          <div class="collection-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title }}"
                  loading="lazy"
                >
              {% endif %}
              <h2 class="collection-card-title">
                {{ product.title }}
              </h2>
              <div class="collection-card-price">
                {{ product.price | money }}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p>No products found in this collection.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "General"
    }
  ]
}
{% endschema %}
