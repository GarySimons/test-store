<div class="announcement-bar" style="background-color: {{ section.settings.bg_color }};">
  <div class="announcement-bar__inner" style="color: {{ section.settings.text_color }};">
    {{ section.settings.text }}
  </div>
</div>

<style>
  .announcement-bar {
    width: 100%;
    padding: 10px 16px;
    text-align: center;
    font-size: 14px;
  }

  .announcement-bar__inner {
    max-width: 900px;
    margin: 0 auto;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over £50"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Header"
    }
  ]
}
{% endschema %}
