{% stylesheet %}
  .custom-page {
    margin: 0 auto;
    padding: 40px 0;
  }

  .custom-page__header {
    margin-bottom: 30px;
    text-align: left;
  }

  .custom-page__header h1 {
    font-size: 42px;
    margin: 0;
  }

  .custom-page__content {
    margin-bottom: 50px;
    line-height: 1.7;
  }

  .custom-page__extra {
    background: #f5f5f5;
    padding: 30px;
    border-radius: 12px;
    text-align: center;
  }

  .button {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 24px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
  }

  .button:hover {
    opacity: 0.85;
  }
{% endstylesheet %}

<div class="container">
  <div class="custom-page">
    {% if page.title != blank %}
      <header class="custom-page__header">
        <h1>{{ page.title }}</h1>
      </header>
    {% endif %}

    {% if page.content != blank %}
      <div class="custom-page__content rte">
        {{ page.content }}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Main Page",
  "settings": [],
  "presets": [
    {
      "name": "Main Page"
    }
  ]
}
{% endschema %}
