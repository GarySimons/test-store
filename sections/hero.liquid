<section class="hero" style="background-color: {{ section.settings.bg_color }};">
  <div class="hero__container">
    <div class="hero__content">
      <h1 class="hero__title" style="color: {{ section.settings.text_color }};">
        {{ section.settings.heading }}
      </h1>

      <p class="hero__subtitle" style="color: {{ section.settings.text_color }};">
        {{ section.settings.subheading }}
      </p>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="hero__button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    {% if section.settings.image != blank %}
      <div class="hero__image">
        {{ section.settings.image | image_url: width: 1000 | image_tag }}
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero {
    padding: 80px 20px;
  }

  .hero__container {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .hero__content {
    flex: 1;
  }

  .hero__title {
    font-size: 48px;
    margin: 0 0 16px;
    line-height: 1.1;
  }

  .hero__subtitle {
    font-size: 18px;
    margin: 0 0 24px;
    opacity: 0.8;
  }

  .hero__button {
    display: inline-block;
    padding: 12px 20px;
    background: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 14px;
  }

  .hero__button:hover {
    opacity: 0.85;
  }

  .hero__image img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero__container {
      flex-direction: column;
      text-align: center;
    }

    .hero__title {
      font-size: 34px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build a beautiful store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A clean, modern Shopify theme section you can fully customize."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Hero section",
      "category": "General"
    }
  ]
}
{% endschema %}
